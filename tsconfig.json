{
  "files": [
    "globals.d.ts"
  ],
  "include": [
    "**/*"
  ],
  "exclude": [
    "./bin",
    "./functions",
    "./node_modules",
    "./.build",
    "**/*.test.ts",
    "**/*.test.js",
    "**/*.spec.ts",
    "**/*.spec.js"
  ],
  "compilerOptions": {
    "outDir": ".build",
    "allowJs": true,
    "declaration": false,
    "sourceMap": false,
    "target": "ESNext",
    "module": "CommonJS",
    "noImplicitAny": true,
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": [
      "ESNext"
    ],
    "types": ["node", "jest"],
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "paths": {
      "@turf/turf": ["./node_modules/@turf/turf/index.d.ts"],
      "yaml": ["./node_modules/yaml/dist/index.d.ts"]
    }
  }
}
